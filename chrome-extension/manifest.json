{
  "manifest_version": 3,
  "name": "Time Tracker",
  "version": "0.1.0",
  "description": "Quick timer popup for the local Time Tracker app.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Time Tracker",
    "default_icon": {
      "16": "icons/favicon.png",
      "32": "icons/favicon.png",
      "48": "icons/favicon.png",
      "128": "icons/favicon.png"
    }
  },
  "icons": {
    "16": "icons/favicon.png",
    "32": "icons/favicon.png",
    "48": "icons/favicon.png",
    "128": "icons/favicon.png"
  },
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "storage"
  ]
}
